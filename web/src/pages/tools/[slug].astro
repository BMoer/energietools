---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import SchematicThumb from "../../components/SchematicThumb.astro";

export async function getStaticPaths() {
  const tools = await getCollection("tools");
  return tools.map((tool) => ({ params: { slug: tool.id }, props: { tool } }));
}

const { tool } = Astro.props;
const d = tool.data;
const { Content } = await render(tool);
const hosted = d.hosting === "hosted";
// hosted → direkter interner Link · external → über den Klickzähler /go/<slug>
const openHref = hosted ? d.url : `/go/${tool.id}`;
const contactIsUrl = /^https?:\/\//.test(d.contact);
const contactHref = contactIsUrl ? d.contact : `mailto:${d.contact}`;
---

<Base title={`${d.name} — energietools.at`} description={d.description}>
  <article class="shell detail">
    <a class="back label" href="/#galerie">← Galerie</a>

    <header class="detail-head">
      <div class="head-text">
        <span class:list={["badge", hosted ? "badge--hosted" : "badge--external"]}>
          {hosted ? "hosted · läuft auf energietools.at" : "extern · läuft beim Autor"}
        </span>
        <h1>{d.name}</h1>
        <p class="lede">{d.description}</p>
        <div class="tags">{d.tags.map((t) => <span class="tag">{t}</span>)}</div>
      </div>
      <div class="head-thumb"><SchematicThumb seed={tool.id} variant={d.hosting} /></div>
    </header>

    <div class="detail-body">
      <div class="prose">
        <Content />

        <section class="engine">
          <h2>Engine ↔ Eigenleistung</h2>
          <p class="engine-text">{d.engineUsage}</p>
          <!-- TODO (offene Entscheidung, vom Betreiber zu fixieren): formale
               Engine/Produkt-Grenze + Publishing-Bedingung. Bis dahin ist die
               Bruchlinie hier vom Autor beschrieben und gegen das offene Repo
               nachprüfbar, aber die Aufnahme-Regel ist noch nicht final. -->
          <p class="engine-note label">
            Bruchlinie vom Autor beschrieben · gegen das offene Repo nachprüfbar ·
            formale Aufnahme-Regel noch offen (TODO)
          </p>
        </section>
      </div>

      <aside class="side">
        <a class="btn btn--live open-btn" href={openHref}
          {...(hosted ? {} : { rel: "noopener" })}>
          Tool öffnen {hosted ? "→" : "↗"}
        </a>

        <dl class="meta">
          <dt class="label">Betreiber</dt>
          <dd>{d.operator}</dd>
          <dt class="label">Hosting</dt>
          <dd>{hosted ? "energietools.at" : new URL(d.url).host}</dd>
        </dl>

        <div class="contact-box">
          <span class="label">Interesse? Anfrage läuft direkt an den Autor:</span>
          <a class="btn btn--ghost" href={contactHref} target="_blank" rel="noopener">
            {d.contactLabel ?? d.contact}
          </a>
        </div>
        <p class="route-note label">
          energietools.at routet nur — abgeschlossen wird beim jeweiligen Autor.
        </p>
      </aside>
    </div>
  </article>
</Base>

<style>
  .detail { padding: 2rem 24px 0; }
  .back { display: inline-block; margin-bottom: 2rem; }
  .back:hover { color: var(--ink); }
  .detail-head {
    display: grid; grid-template-columns: 1.5fr 1fr; gap: 2.5rem; align-items: center;
    padding-bottom: 2.5rem; border-bottom: 1px solid var(--line-strong);
  }
  .detail-head .badge { display: inline-block; margin-bottom: 1.2rem; }
  .detail-head h1 { font-size: clamp(2.4rem, 6vw, 4.4rem); }
  .lede { font-size: 1.2rem; color: var(--ink-2); max-width: 46ch; margin: 1.2rem 0 1.4rem; }
  .tags { display: flex; flex-wrap: wrap; gap: 7px; }
  .head-thumb {
    aspect-ratio: 16/10; border: 1px solid var(--line-strong); overflow: hidden;
  }

  .detail-body { display: grid; grid-template-columns: 1.6fr 0.9fr; gap: 3rem; padding: 3rem 0 1rem; }
  .prose :global(p) { color: var(--ink-2); }
  .prose :global(h2) { margin: 2rem 0 0.8rem; }
  .prose :global(blockquote) {
    border-left: 3px solid var(--live); padding-left: 1rem; margin: 1.4rem 0;
    color: var(--muted); font-style: italic;
  }
  .prose :global(code) {
    font-family: var(--mono); font-size: 0.86em; background: var(--paper-2);
    padding: 1px 5px; border: 1px solid var(--line); border-radius: 3px;
  }
  .engine {
    margin-top: 2.5rem; padding: 1.6rem; background: var(--paper-2);
    border: 1px solid var(--line-strong); border-left: 4px solid var(--live);
  }
  .engine h2 { margin: 0 0 0.8rem; font-size: 1.5rem; }
  .engine-text { color: var(--ink); font-size: 0.98rem; margin-bottom: 1rem; }
  .engine-note { display: block; line-height: 1.5; }

  .side { position: sticky; top: 88px; align-self: start; display: flex; flex-direction: column; gap: 1.4rem; }
  .open-btn { justify-content: center; font-size: 0.95rem; padding: 1em; }
  .meta { margin: 0; display: grid; grid-template-columns: max-content 1fr; gap: 0.5rem 1rem; }
  .meta dd { margin: 0; font-weight: 600; }
  .contact-box {
    display: flex; flex-direction: column; gap: 0.7rem;
    padding: 1.2rem; border: 1px dashed var(--line-strong); border-radius: var(--radius);
  }
  .contact-box .btn { justify-content: center; }
  .route-note { line-height: 1.5; }

  @media (max-width: 820px) {
    .detail-head { grid-template-columns: 1fr; }
    .head-thumb { order: -1; }
    .detail-body { grid-template-columns: 1fr; gap: 2rem; }
    .side { position: static; }
  }
</style>
